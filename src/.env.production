# Production env template — values pasted into Vercel → Settings → Environment Variables.
# Real values live in .env.production.local (gitignored). Do not commit secrets here.

# Public — safe to expose in client bundle
NEXT_PUBLIC_N8N_URL=https://api.narativ.space
NEXT_PUBLIC_SUPABASE_URL=https://arujkowiihftpghmxlwv.supabase.co

# Supabase — server only
SUPABASE_URL=https://arujkowiihftpghmxlwv.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=

# NextAuth
NEXTAUTH_URL=https://social-growth-saas.vercel.app
NEXTAUTH_SECRET=

# Anthropic / Apify — only used by n8n on the droplet, not by Vercel.
# Keep a copy here only for single-source-of-truth convenience.
ANTHROPIC_API_KEY=
APIFY_API_TOKEN=
INSTAGRAM_SESSION_ID=
