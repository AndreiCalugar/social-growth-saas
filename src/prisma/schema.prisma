generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platform     String
  username     String
  profile_url  String?
  is_own       Boolean       @default(false)
  followers    Int?
  following    Int?
  bio          String?
  last_scraped DateTime?     @db.Timestamptz(6)
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  posts        Post[]
  scrape_runs  ScrapeRun[]
  analyses     Analysis[]
  recommendations Recommendation[]

  @@unique([platform, username])
  @@map("profiles")
}

model Post {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id       String    @db.Uuid
  platform_post_id String    @unique
  content_type     String?
  caption          String?
  hashtags         Json      @default("[]")
  likes            Int?
  comments         Int?
  shares           Int?
  views            Int?
  engagement_rate  Float?
  posted_at        DateTime? @db.Timestamptz(6)
  scraped_at       DateTime  @default(now()) @db.Timestamptz(6)
  profile          Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@index([platform_post_id])
  @@index([posted_at])
  @@map("posts")
}

model ScrapeRun {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id     String    @db.Uuid
  apify_run_id   String?
  status         String    @default("pending")
  posts_scraped  Int       @default(0)
  started_at     DateTime  @default(now()) @db.Timestamptz(6)
  completed_at   DateTime? @db.Timestamptz(6)
  profile        Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@map("scrape_runs")
}

model Analysis {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id            String          @db.Uuid
  analysis_type         String          @default("performance")
  engagement_summary    Json?
  top_posts             Json?
  worst_posts           Json?
  best_posting_times    Json?
  content_type_breakdown Json?
  raw_response          String?
  created_at            DateTime        @default(now()) @db.Timestamptz(6)
  profile               Profile         @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  recommendations       Recommendation[]

  @@index([profile_id])
  @@index([created_at])
  @@map("analyses")
}

model Recommendation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id  String   @db.Uuid
  analysis_id String   @db.Uuid
  category    String
  title       String
  description String?
  priority    String   @default("medium")
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  profile     Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  analysis    Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@index([analysis_id])
  @@index([priority])
  @@map("recommendations")
}
